OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
# Groq has no embeddings API — use huggingface for vectors, or set EMBEDDING_OPENAI_BASE_URL to https://api.openai.com/v1
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional: separate OpenAI base for embeddings only (must NOT be Groq)
EMBEDDING_OPENAI_BASE_URL=
VECTOR_STORE=chroma
VECTOR_STORE_DIR=data/vector_store
# MySQL (XAMPP) — same DB for Django + RAG
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3310/smartphone
TEXT_FILES_DIR=data/text_files
MAX_CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=6
KEYWORD_TOP_K=8
VECTOR_TOP_K=8
RERANK_TOP_N=6
RERANKER_TYPE=llm
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MULTI_QUERY_COUNT=3
MAX_CONTEXT_CHARS=6000
MAX_HISTORY_TURNS=10
DEBUG_MODE=true
RAG_LOG_FILE=data/logs/rag_pipeline.log
RESPONSE_CACHE_TTL_SECONDS=900
ENABLE_TOOLS=true
DJANGO_SECRET_KEY=change_me_for_production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
